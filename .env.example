# Optional: public base URL for frame JPEGs (Cloudflare R2 r2.dev or custom domain).
# Leave unset to load from Next.js public/ (e.g. public/bikers-frames/0001.jpg).
# No trailing slash on the base. Required on Vercel if frame folders are gitignored.
# VITE_FRAMES_CDN_BASE=https://pub-xxxxxxxxxxxx.r2.dev

# Next.js (browser) — set this in Vercel Project → Environment Variables for production.
# NEXT_PUBLIC_FRAMES_CDN_BASE=https://pub-xxxxxxxxxxxx.r2.dev

# Staff panel (obscured URL — change NEXT_PUBLIC_OCC_STAFF_PREFIX in production)
# Public entry: {PREFIX}  e.g. http://localhost:3000/k9xm2p7qv4nw8-stf
# Staff login only: {PREFIX}/gate
NEXT_PUBLIC_OCC_STAFF_PREFIX="/k9xm2p7qv4nw8-stf"

# Seed + first staff login (set strong values in .env.local; never commit real secrets)
OCC_STAFF_ADMIN_EMAIL="occ-staff-r8k2@occ-local.dev"
OCC_STAFF_ADMIN_PASSWORD="Kx9#mQ2$vL8nW4pR@bF7tY1z"

# Auth backend (Prisma + JWT)
# Provide a Postgres connection string for Prisma.
# Render typically gives you a URL like:
# postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require
DATABASE_URL="postgresql://ccccccccccccccccccccccccau10-a.oregon-postgres.render.com/occ_4t52"

# Vercel: add DATABASE_URL (same as production DB) to Build + Runtime env so `prisma db push`
# in vercel.json can create tables on first deploy. Host app on Vercel + DB on Render is fine.

# Optional: Prisma direct connection (bypasses pooling) if you have it.
# (Not required: Prisma will use DATABASE_URL if DIRECT_URL is not set.)

# Used to sign login sessions. Put a long random string.
JWT_SECRET="change-me-to-a-long-random-secret"

# OTP email verification (choose one provider)
# Resend is the easiest option on Vercel:
# RESEND_API_KEY="re_..."
# RESEND_FROM="OCC <onboarding@resend.dev>"
#
# Or use SMTP:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-smtp-password-or-app-password"
SMTP_FROM="OCC<your-email@gmail.com>"

# Pusher realtime
PUSHER_APP_ID="your_app_id"
PUSHER_KEY="your_key"
PUSHER_SECRET="your_secret"
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY="your_key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# Profile photo uploads on Vercel (optional locally — falls back to public/uploads/)
# Create a Blob store in Vercel → Storage; token is injected as BLOB_READ_WRITE_TOKEN on deploy.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Cloudflare R2 public bucket URL for scroll-animation frames (no trailing slash).
# NEXT_PUBLIC_R2_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# If legacy post/avatar URLs in the DB are like `/uploads/userId/file.jpg`, mirror those paths on R2
# and set the bucket public origin (no trailing slash). Production will load images from R2 instead of 404.
# Example: object key in bucket `uploads/abc/file.jpg` → https://pub-xxx.r2.dev/uploads/abc/file.jpg
# NEXT_PUBLIC_UPLOADS_CDN_BASE="https://pub-xxxxxxxxxxxx.r2.dev"
# Alias: NEXT_PUBLIC_R2_UPLOADS_BASE (same value)

# Service worker toggle — set to "false" to disable frame caching SW.
# NEXT_PUBLIC_SW_ENABLED="true"

# Google OAuth (Web client) — add Authorized redirect URIs in Google Cloud Console:
#   http://localhost:3000/api/auth/google/callback
#   https://www.offcampusclub.com/api/auth/google/callback
#   https://off-campus-club.vercel.app/api/auth/google/callback
# Optional: set GOOGLE_REDIRECT_URI to a single fixed URL if your host headers are wrong (otherwise the app builds the callback URL from the request).
# GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="..."
# GOOGLE_REDIRECT_URI="https://www.offcampusclub.com/api/auth/google/callback"
