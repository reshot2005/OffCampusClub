generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String              @id @default(cuid())
  fullName               String
  collegeName            String
  phoneNumber            String              @unique
  email                  String              @unique
  password               String
  emailVerified          DateTime?
  avatar                 String?
  bio                    String?
  city                   String?
  graduationYear         Int?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  approvalStatus         ApprovalStatus      @default(APPROVED)
  clubManagedId          String?
  referralCode           String?             @unique
  referredBy             String?
  role                   UserRole            @default(STUDENT)
  suspended              Boolean             @default(false)
  announcements          Announcement[]
  memberships            ClubMembership[]
  clubManaged            Club?               @relation("ClubHeader")
  postComments           Comment[]
  registrations          EventRegistration[]
  gigsApplied            GigApplication[]
  notifications          Notification[]
  postLikes              PostLike[]
  posts                  Post[]
  shares                 Share[]
  follows                Follow[]            @relation("follows")
  followedBy             Follow[]            @relation("followedBy")
  referralStatsAsHeader  ReferralStat[]      @relation("ReferralHeader")
  referralStatsAsStudent ReferralStat[]      @relation("ReferralStudent")
  referrer               User?               @relation("ReferralRelation", fields: [referredBy], references: [id])
  referrals              User[]              @relation("ReferralRelation")
  commentReports         CommentReport[]

  @@map("users")
}

model Club {
  id            String           @id @default(cuid())
  slug          String           @unique
  name          String
  icon          String
  description   String
  theme         String
  coverImage    String?
  memberCount   Int              @default(0)
  createdAt     DateTime         @default(now())
  headerId      String?          @unique
  postingFrozen Boolean          @default(false)
  announcements Announcement[]
  members       ClubMembership[]
  header        User?            @relation("ClubHeader", fields: [headerId], references: [id])
  events        Event[]
  posts         Post[]
  referralStats ReferralStat[]

  @@map("clubs")
}

model ClubMembership {
  id       String   @id @default(cuid())
  userId   String
  clubId   String
  joinedAt DateTime @default(now())
  role     String   @default("member")
  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@map("club_memberships")
}

model Event {
  id            String              @id @default(cuid())
  clubId        String
  title         String
  description   String
  date          DateTime
  venue         String
  price         Int                 @default(0)
  maxCapacity   Int?
  imageUrl      String              @default("")
  createdAt     DateTime            @default(now())
  registrations EventRegistration[]
  club          Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("events")
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  status    String   @default("registered")
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_registrations")
}

model Post {
  id          String     @id @default(cuid())
  userId      String
  clubId      String
  imageUrl    String?
  caption     String?
  likes       Int        @default(0)
  createdAt   DateTime   @default(now())
  content     String?
  imageUrls   String[]   @default([])
  likesCount  Int        @default(0)
  sharesCount Int        @default(0)
  type        String     @default("post")
  hidden      Boolean    @default(false)
  pinned      Boolean    @default(false)
  comments    Comment[]
  postLikes   PostLike[]
  shares      Share[]
  club        Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports   CommentReport[]

  @@map("comments")
}

model CommentReport {
  id          String   @id @default(cuid())
  commentId   String
  reporterId  String
  reason      String
  createdAt   DateTime @default(now())
  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("comment_reports")
}


model Announcement {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ReferralStat {
  id           String   @id @default(cuid())
  clubHeaderId String
  studentId    String
  registeredAt DateTime @default(now())
  clubId       String
  clubHeader   User     @relation("ReferralHeader", fields: [clubHeaderId], references: [id], onDelete: Cascade)
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  student      User     @relation("ReferralStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("referral_stats")
}

model Gig {
  id           String           @id @default(cuid())
  title        String
  description  String
  payMin       Int
  payMax       Int
  clubId       String?
  deadline     DateTime?
  createdAt    DateTime         @default(now())
  applications GigApplication[]

  @@map("gigs")
}

model GigApplication {
  id        String   @id @default(cuid())
  userId    String
  gigId     String
  status    String   @default("applied")
  createdAt DateTime @default(now())
  gig       Gig      @relation(fields: [gigId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gigId])
  @@map("gig_applications")
}

model EmailOtpToken {
  id           String     @id @default(cuid())
  email        String
  purpose      OtpPurpose
  codeHash     String
  attemptsLeft Int        @default(5)
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime   @default(now())

  @@index([email, purpose, expiresAt])
  @@map("email_otp_tokens")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followedBy", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Share {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shares")
}

enum UserRole {
  STUDENT
  CLUB_HEADER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OtpPurpose {
  REGISTER
  RESET_PASSWORD
}
