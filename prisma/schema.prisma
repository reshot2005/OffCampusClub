generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminActionLog {
  id         String   @id
  adminId    String
  actionType String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Category {
  id        String   @id
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  Club      Club[]
}

model Club {
  id                                String             @id
  name                              String
  slug                              String             @unique
  description                       String
  categoryId                        String?
  university                        String?
  locationName                      String?
  latitude                          Float?
  longitude                         Float?
  logoUrl                           String?
  bannerUrl                         String?
  isActive                          Boolean            @default(true)
  approvalStatus                    ClubApprovalStatus @default(PENDING)
  isVerified                        Boolean            @default(false)
  reviewedAt                        DateTime?
  reviewedByAdminId                 String?
  rejectionReason                   String?
  visibility                        ClubVisibility     @default(PUBLIC)
  ownerId                           String
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime
  Category                          Category?          @relation(fields: [categoryId], references: [id])
  User_Club_ownerIdToUser           User               @relation("Club_ownerIdToUser", fields: [ownerId], references: [id], onDelete: Cascade)
  User_Club_reviewedByAdminIdToUser User?              @relation("Club_reviewedByAdminIdToUser", fields: [reviewedByAdminId], references: [id])

  @@index([approvalStatus, createdAt])
  @@index([approvalStatus, isActive])
  @@index([slug])
  @@index([university])
}

model ClubJoinRequest {
  id        String            @id
  clubId    String
  userId    String
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([clubId, status])
  @@index([userId])
}

model ClubMember {
  id             String         @id
  clubId         String
  userId         String
  membershipRole MembershipRole @default(MEMBER)
  joinedAt       DateTime       @default(now())

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model Comment {
  id        String   @id
  postId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([postId])
}

model Gig {
  id               String           @id
  title            String
  slug             String           @unique
  shortDescription String
  fullDescription  String
  category         String
  pricing          String?
  instructions     String?
  requirements     String?
  bannerUrl        String?
  isActive         Boolean          @default(true)
  isPublic         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  GigApplication   GigApplication[]

  @@index([category])
  @@index([isActive, isPublic])
  @@index([slug])
}

model GigApplication {
  id                                          String               @id
  userId                                      String?
  gigId                                       String
  name                                        String
  email                                       String
  phone                                       String
  college                                     String
  reason                                      String
  relevantExperience                          String?
  status                                      GigApplicationStatus @default(PENDING)
  reviewedByAdminId                           String?
  reviewedAt                                  DateTime?
  createdAt                                   DateTime             @default(now())
  updatedAt                                   DateTime
  Gig                                         Gig                  @relation(fields: [gigId], references: [id], onDelete: Cascade)
  User_GigApplication_reviewedByAdminIdToUser User?                @relation("GigApplication_reviewedByAdminIdToUser", fields: [reviewedByAdminId], references: [id])
  User_GigApplication_userIdToUser            User?                @relation("GigApplication_userIdToUser", fields: [userId], references: [id])

  @@unique([userId, gigId])
  @@index([email, gigId])
  @@index([gigId, status])
  @@index([status, createdAt])
  @@index([userId, status])
}

model Like {
  id        String   @id
  postId    String
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model Post {
  id               String           @id
  authorId         String
  clubId           String?
  content          String
  imageUrl         String?
  visibility       PostVisibility   @default(PUBLIC)
  moderationStatus ModerationStatus @default(PUBLISHED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  deletedAt        DateTime?

  @@index([authorId])
  @@index([clubId, deletedAt, moderationStatus, createdAt])
  @@index([clubId])
  @@index([createdAt])
  @@index([deletedAt, createdAt])
  @@index([deletedAt])
  @@index([moderationStatus, deletedAt, createdAt])
}

model PrivacySetting {
  id                    String            @id
  userId                String            @unique
  profileVisibility     ProfileVisibility @default(PUBLIC)
  showUniversity        Boolean           @default(true)
  showClubMembership    Boolean           @default(true)
  postVisibilityDefault PostVisibility    @default(PUBLIC)
  updatedAt             DateTime
}

model Profile {
  id          String   @id
  userId      String   @unique
  displayName String
  bio         String?
  university  String?
  phoneNumber String?
  hobbies     String?
  avatarUrl   String?
  coverUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Report {
  id                String       @id
  postId            String
  reporterId        String
  reason            String
  description       String?
  status            ReportStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime     @default(now())

  @@index([status, createdAt])
  @@index([status])
}

model Share {
  id        String   @id
  postId    String
  userId    String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model User {
  id                                                    String               @id
  email                                                 String               @unique
  passwordHash                                          String
  role                                                  UserRole             @default(USER)
  status                                                UserStatus           @default(ACTIVE)
  isActive                                              Boolean              @default(true)
  createdAt                                             DateTime             @default(now())
  updatedAt                                             DateTime
  Club_Club_ownerIdToUser                               Club[]               @relation("Club_ownerIdToUser")
  Club_Club_reviewedByAdminIdToUser                     Club[]               @relation("Club_reviewedByAdminIdToUser")
  GigApplication_GigApplication_reviewedByAdminIdToUser GigApplication[]     @relation("GigApplication_reviewedByAdminIdToUser")
  GigApplication_GigApplication_userIdToUser            GigApplication[]     @relation("GigApplication_userIdToUser")
  PasswordResetToken                                    PasswordResetToken[]
  Profile                                               Profile?
  RefreshToken                                          RefreshToken[]

  @@index([role])
  @@index([status])
}

model UserSetting {
  id                      String   @id
  userId                  String   @unique
  themePreference         String   @default("system")
  notificationPreferences Json     @default("{}")
  updatedAt               DateTime
}

enum UserRole {
  USER
  CLUB_ADMIN
  PLATFORM_ADMIN
  SUPER_ADMIN
}

enum ClubApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClubVisibility {
  PUBLIC
  PRIVATE
}

enum GigApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ModerationStatus {
  PENDING
  PUBLISHED
  REJECTED
  REMOVED
}

enum PostVisibility {
  PUBLIC
  CLUB
  MEMBERS_ONLY
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}
